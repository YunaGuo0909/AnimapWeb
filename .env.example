# Get a free token at https://account.mapbox.com/ then set:
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# Optional: IUCN Red List API (free, non-commercial). Get token at https://api.iucnredlist.org/
